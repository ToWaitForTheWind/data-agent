{
  "name": "data-agent",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "check-types": "pnpm -r run check-types",
    "dev": "pnpm --parallel --filter @data-agent/client --filter @data-agent/web run dev",
    "dev:client": "pnpm --filter @data-agent/client dev",
    "dev:web": "pnpm --filter @data-agent/web dev",
    "build": "pnpm --filter @data-agent/client --filter @data-agent/web run build"
  }
}
